---
import { getCollection } from 'astro:content';
import RootLayout from '../../layouts/RootLayout.astro';

export async function getStaticPaths() {
    const books = await getCollection('books');
    return books.map((book) => ({
        params: { id: book.id },
        props: { book }
    }));
}

const { book } = Astro.props;
---

<RootLayout title={book.data.title}>
    <div class="flex flex-col gap-8">
        <div class="flex flex-col md:flex-row items-center md:items-start gap-12">
            <img class="book-cover w-48 md:w-64 shadow-2xl" src={book.data.cover} />
            <div class="flex flex-col gap-4">
                <h1 class="text-5xl md:text-7xl font-serif font-semibold">{book.data.title}</h1>
                <h2 class="text-xl md:text-3xl font-serif">{book.data.subtitle}</h2>
                <p class="text-lg">by Joe Attardi</p>
                <p class="text-lg md:text-3xl text-slate-600">{book.data.summary}</p>
                <div class="flex flex-wrap items-center gap-3">
                    <a
                        href={book.data.amazonUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex w-fit items-center justify-center rounded-md bg-yellow-400 px-5 py-3 text-base font-semibold text-slate-900 transition-colors hover:bg-yellow-500 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-yellow-500 focus-visible:ring-offset-2"
                    >
                        Buy from Amazon
                    </a>
                    {book.data.websiteUrl && (
                        <a
                            href={book.data.websiteUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex w-fit items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-3 text-base font-semibold text-slate-900 transition-colors hover:bg-slate-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2"
                        >
                            Visit Book Website
                        </a>
                    )}
                </div>
                {book.data.buyLinks && book.data.buyLinks.length > 0 && (
                    <p class="text-sm text-slate-500">
                        Also available at{' '}
                        {book.data.buyLinks.map((link, index) => (
                            <>
                                {index > 0 && <span aria-hidden="true"> • </span>}
                                <a
                                    href={link.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="underline decoration-slate-300 underline-offset-2 transition-colors hover:text-slate-700"
                                >
                                    {link.name}
                                </a>
                            </>
                        ))}
                    </p>
                )}
            </div>
        </div>
        <div class="flex flex-col gap-4">
            <h2 class="text-4xl font-serif">Contents</h2>
            <ul class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {book.data.contents.map((chapter, index) => (
                    <li class="flex flex-col gap-1 bg-white p-4 border border-slate-300 rounded-lg">
                        <small class="text-slate-600 uppercase tracking-wider">Chapter {index + 1}</small>
                        <h3 class="text-xl font-bold">{chapter.title}</h3>
                        <p>{chapter.description}</p>
                    </li>
                ))}
            </ul>
        </div>
    </div>
</RootLayout>

<style>
    .book-cover {
        transition: rotate 0.5s ease, scale 0.5s ease, opacity 0.5s ease;
        opacity: 1;
        rotate: -6deg;
        scale: 1;
    }

    @starting-style {
        .book-cover {
            rotate: 0deg;
            scale: 0.5;
            opacity: 0;
        }
    }
</style>