---
import RootLayout from '../layouts/RootLayout.astro';
import avatar from '../assets/images/joe.png';
import oreillyLogo from '../assets/images/OReilly_logo_rgb.png';
import apressLogo from '../assets/images/Apress-logo.png';
import smashingLogo from '../assets/images/Smashing Magazine Logo.webp';
import logrocketLogo from '../assets/images/logrocket.png';
import freecodecampLogo from '../assets/images/freecodecamp.png';
import { Image } from 'astro:assets';
---

<RootLayout>
    <div class="layout p-8">
        <h1 class="title font-bold text-5xl md:text-6xl font-serif justify-self-center md:justify-self-start">Joe Attardi</h1>
        <div class="description flex flex-col gap-4">
            <p class="text-xl">
                I'm a software engineer with a deep love for the modern JavaScript ecosystem. I
                spend my days building functional web applications and my nights staying ahead of
                the ever-evolving web.
            </p>
            <p class="text-xl">
                Beyond the code, I'm also a published author, sharing my insights and experiences
                through writing. Whether it's crafting engaging articles or contributing to
                open-source projects, I enjoy connecting with the developer community and helping
                others navigate the complexities of web development.
            </p>
        </div>
        <Image
            class="justify-self-center photo w-48 h-48 md:w-72 md:h-72 rounded-full border-8 border-slate-600"
            src={avatar}
            alt="Photo of Joe Attardi"
        />
    </div>

    <div class="publishers">
        <p class="publishers-label">Published with</p>
        <div class="publishers-logos">
            <Image src={oreillyLogo} alt="O'Reilly Media" height={28} class="publisher-logo" />
            <Image src={apressLogo} alt="Apress" height={28} class="publisher-logo" />
            <Image src={smashingLogo} alt="Smashing Magazine" height={28} class="publisher-logo" />
            <Image src={logrocketLogo} alt="LogRocket" height={28} class="publisher-logo" />
            <Image src={freecodecampLogo} alt="freeCodeCamp" height={28} class="publisher-logo" />
        </div>
    </div>
</RootLayout>

<style>
    .layout {
        display: grid;
        grid-template-areas:
            'title photo'
            'description photo';
        grid-template-columns: 1fr auto;
        grid-template-rows: auto 1fr;
        gap: 1rem;
        column-gap: 4rem;
    }

    .title {
        grid-area: title;
    }

    .description {
        grid-area: description;
    }

    .photo {
        grid-area: photo;
    }

    .publishers {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.25rem;
        padding: 2.5rem 0 1rem;
        border-top: 1px solid #e2e8f0;
        margin-top: 2rem;
    }

    .publishers-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
    }

    .publishers-logos {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 2.5rem 3.5rem;
    }

    .publisher-logo {
        width: auto;
        object-fit: contain;
        opacity: 0.55;
        filter: grayscale(1);
        transition: opacity 150ms ease, filter 150ms ease;
    }

    .publisher-logo:hover {
        opacity: 0.9;
        filter: grayscale(0);
    }

    @media (max-width: 768px) {
        .layout {
            grid-template-areas:
                'photo'
                'title'
                'description';
            grid-template-columns: 1fr;
            grid-template-rows: auto auto auto;
        }
    }
</style>
