---
import RootLayout from '../layouts/RootLayout.astro';
import avatar from '../assets/images/joe.png';
import { Image } from 'astro:assets';
---

<RootLayout>
    <div class="flex gap-8">
        <div class="flex flex-col gap-4">
            <h1 class="font-bold text-6xl">
                20+ years of building, writing, and breaking things (mostly on purpose).
            </h1>
            <p class="text-xl">
                I'm a front-end obsessed software engineer with a deep love for the modern
                JavaScript ecosystem. I spend my days building functional web applications and my
                nights staying ahead of the ever-evolving web.
            </p>
            <p class="text-xl">
                Beyond the code, I'm also a published author, sharing my insights and experiences
                through writing. Whether it's crafting engaging articles or contributing to
                open-source projects, I enjoy connecting with the developer community and helping
                others navigate the complexities of web development.
            </p>
        </div>
        <Image class="w-96 h-96 rounded-full" src={avatar} alt="Photo of Joe Attardi" />
    </div>
</RootLayout>
