---
const { href } = Astro.props;
---

<li>
    <a
        href={href}
        class="rounded-full border border-transparent px-4 py-2 text-sm font-semibold tracking-[0.02em] text-slate-700 transition-all hover:-translate-y-0.5 hover:border-blue-200 hover:bg-white/80 hover:text-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
    >
        <slot />
    </a>
</li>
