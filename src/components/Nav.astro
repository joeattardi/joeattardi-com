---
interface Props {
    navLinks: { href: string; label: string }[];
}

import NavLink from './NavLink.astro';
const { navLinks } = Astro.props;
---

<nav aria-label="Primary" class="hidden sm:block">
    <ul class="flex flex-wrap items-center gap-1 sm:gap-2">
        {navLinks.map((link) => <NavLink href={link.href}>{link.label}</NavLink>)}
    </ul>
</nav>
