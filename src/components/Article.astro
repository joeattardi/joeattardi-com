---
import { Icon } from 'astro-icon/components';

interface Props {
    article: {
        title: string;
        publishedDate: string;
        url: string;
        publication: string;
        description: string;
        tags: string[];
        featured?: boolean;
    };
}

const { article } = Astro.props;
---

<article class="flex flex-col gap-2 items-start border border-slate-300 bg-slate-100 p-4">
    <div class="py-2 flex flex-col gap-2">
        <h2 class="text-2xl md:text-3xl font-serif">
            <a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-indigo-600">{article.title}</a
            >
        </h2>
        <div
            class="flex items-start md:flex-row md:items-center gap-2 uppercase tracking-wider font-semibold text-slate-500 text-sm flex-col"
        >
            <span
                >{
                    new Date(article.publishedDate).toLocaleDateString(undefined, {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                    })
                }</span
            >
            <span class="hidden md:block">|</span>
            <span>{article.publication}</span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
            {
                article.tags.map((tag) => (
                    <span class="text-sm font-medium text-slate-600 bg-slate-200 px-2 py-1 rounded">
                        {tag}
                    </span>
                ))
            }
        </div>
    </div>
    <p class="text-lg text-slate-700">{article.description}</p>
    <a
        href={article.url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-indigo-600"
    >
        Read more
        <Icon name="fa7-solid:arrow-right" />
    </a>
</article>
