---
const { book } = Astro.props;
---
<article class="flex flex-col md:flex-row gap-4 items-start border border-l-8 border-l-indigo-600 border-slate-300 bg-white rounded-lg p-4">
    <a href={book.href} target="_blank" rel="noopener noreferrer">
        <img class="w-32" src={book.cover} />
    </a>
    <div class="flex flex-col gap-2">
        <h2 class="text-3xl font-serif">
            <a href={book.href} target="_blank" rel="noopener noreferrer" class="text-indigo-600">{book.title}</a>
        </h2>
        <p class="text-sm text-gray-600 uppercase tracking-wider font-semibold">{book.publisher}, {book.year}</p>
    </div>
</article>
